import java.util.*;
 public class rectanglePattern {
    public static void main(String []args) {
        System.out.println("Enter the length of rectangle:");
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        System.out.println("Enter the breadth of rectangle:");
        int m = sc.nextInt();
        for(int i = 0; i< n;i++){
            for(int j = 0;j<m;j++){
                System.out.print("  *");
            }
             System.out.print("\n");
        }
    }
}